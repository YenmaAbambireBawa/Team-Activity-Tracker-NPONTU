APP_NAME="Team Activity Tracker"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=error

# Railway injects these automatically when you add a MySQL plugin.
# Copy the values from your Railway MySQL service into these fields.
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=480

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
